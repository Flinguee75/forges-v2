# URL du dépôt Git FORGES (privé ou public)
# Format SSH  : git@github.com:votre-org/forges-backend.git
# Format HTTPS: https://github.com/votre-org/forges-backend.git
FORGES_REPO_URL=https://github.com/forges-group/forges-backend.git
