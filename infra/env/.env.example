# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forges_user:forges_pass@localhost:5432/forges_db
POSTGRES_DB=forges_db
POSTGRES_USER=forges_user
POSTGRES_PASSWORD=forges_pass

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@localhost:6379
REDIS_PASSWORD=redis_pass

# ── Sécurité JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=changeme_64chars_minimum_required_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=changeme_64chars_minimum_required_xxxxxxxxxxxxxxxxxxxxxxxx
ENCRYPTION_KEY=changeme_32bytes_base64_encoded_xxxxxxxxxxxxxxxxxxxxxxxxxx
HMAC_KEY=changeme_32bytes_hex_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_SECRET=changeme_webhook_secret

# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://demo.forges-group.com

# ── Docker deploy ──────────────────────────────────────────────────────────────
BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_ORG/forges-backend
IMAGE_TAG=latest
BACKEND_PORT=3000
BACKEND_INTERNAL_PORT=3000
GHCR_USERNAME=YOUR_GITHUB_USERNAME
GHCR_TOKEN=YOUR_GHCR_TOKEN

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass

# ── Paiement ───────────────────────────────────────────────────────────────────
PAYMENT_API_URL=https://api.payment-provider.com
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret
