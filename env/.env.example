# =====================================================
# FORGES - Variables d'environnement
# =====================================================
# Copier ce fichier en .env.dev, .env.test ou .env.demo
# puis adapter les valeurs selon l'environnement cible.
# =====================================================

# ---------------------------
# 1. APPLICATION
# ---------------------------
NODE_ENV=development          # development | test | production
APP_ENV=dev                   # dev | test | demo
PORT=3000                     # Port de l'API backend

# ---------------------------
# 2. BASE DE DONNÉES (PostgreSQL)
# ---------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://forges_user:strong_password@localhost:5432/forges_dev

# Exemples par environnement :
# dev   : postgresql://forges_user:pass@dev-db.forges-group.com:5432/forges_dev
# test  : postgresql://forges_user:pass@test-db.forges-group.com:5432/forges_test
# demo  : postgresql://forges_user:pass@demo-db.forges-group.com:5432/forges_demo

# ---------------------------
# 3. REDIS (Cache, sessions, rate limiting)
# ---------------------------
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@redis-host:6379/0

# ---------------------------
# 4. JWT (Authentification)
# ---------------------------
# Générer des clés fortes (32+ caractères aléatoires)
JWT_SECRET=supersecret_jwt_key_change_me
JWT_REFRESH_SECRET=supersecret_refresh_key_change_me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------
# 5. CHIFFREMENT (MT-02)
# ---------------------------
# Clé AES-256-GCM (32 bytes en base64)
ENCRYPTION_KEY=base64_32_bytes_key_change_me

# ---------------------------
# 6. URLS FRONTEND & BACKEND (CORS, emails)
# ---------------------------
FRONTEND_URL=https://dev.forges-group.com
API_URL=https://api-dev.forges-group.com

# Autoriser plusieurs origines séparées par des virgules
CORS_ORIGINS=https://dev.forges-group.com,https://test.forges-group.com,https://demo.forges-group.com

# ---------------------------
# 7. EMAILS (SMTP)
# ---------------------------
SMTP_HOST=smtp.forges-group.com
SMTP_PORT=587
SMTP_USER=noreply@forges-group.com
SMTP_PASS=your_smtp_password
SMTP_SECURE=false                 # true pour TLS (port 465)

# ---------------------------
# 8. PAIEMENTS (Agrégateur Mobile Money)
# ---------------------------
PAYMENT_API_URL=https://api.aggregateur.ci/v1
PAYMENT_API_KEY=your_api_key
PAYMENT_WEBHOOK_SECRET=webhook_secret_change_me

# ---------------------------
# 9. COMMISSIONS & SEUILS (défauts)
# ---------------------------
DEFAULT_COMMISSION_FORGES_PCT=20          # Commission FORGES (partenaires)
DEFAULT_COMMISSION_APPORTEUR_PCT=5        # Commission apporteurs
SEUIL_REVERSEMENT_PARTENAIRE_XOF=50000    # Seuil reversement partenaire (XOF)
SEUIL_REVERSEMENT_APPORTEUR_XOF=5000      # Seuil reversement apporteur (XOF)

# ---------------------------
# 10. ABONNEMENTS & GRACES
# ---------------------------
ABONNEMENT_GRACE_PERIOD_HOURS=48          # Période de grâce après échec paiement
ABONNEMENT_UPGRADE_COOLDOWN_DAYS=7        # Délai entre deux suggestions d'upgrade
ABONNEMENT_SUSPENSION_MAX_PER_QUARTER=1   # Nb max de suspensions par trimestre
ABONNEMENT_SUSPENSION_MAX_DAYS=30         # Durée max d'une suspension

# ---------------------------
# 11. BOT CONSEILLER
# ---------------------------
BOT_FEEDBACK_WINDOW_DAYS=7                # Fenêtre pour feedback post-session
BOT_UPGRADE_COOLDOWN_DAYS=7               # Cooldown upgrade
BOT_MAX_REFUS_BEFORE_LONG_COOLDOWN=3
BOT_LONG_COOLDOWN_DAYS=30

# ---------------------------
# 12. SÉCURITÉ & RATE LIMITING
# ---------------------------
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000       # 15 minutes
RATE_LIMIT_MAX=100                        # Requêtes max par fenêtre
REGISTER_RATE_LIMIT_MAX=5                 # Tentatives max / IP / heure (RM-32)

# ---------------------------
# 13. FICHIERS UPLOAD (RM-49)
# ---------------------------
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png

# ---------------------------
# 14. LOGS & AUDIT (MT-01)
# ---------------------------
LOG_LEVEL=info                            # error | warn | info | debug
HMAC_KEY=hmac_secret_change_me            # Clé pour intégrité des logs

# ---------------------------
# 15. SCHEDULER (node-cron)
# ---------------------------
SESSION_TRANSITION_CRON="0 0 * * *"       # 00h00 quotidien
PAYMENT_EXPIRATION_CRON="0 1 * * *"
RENOUVELLEMENT_CRON="0 6 * * *"
REVERSEMENT_APPORTEUR_CRON="30 0 1 * *"
PURGE_COMPTES_CRON="0 4 * * *"

# =====================================================
# INSTRUCTIONS PAR ENVIRONNEMENT
# =====================================================
# Pour chaque environnement (dev, test, demo) :
# 1. Copier ce fichier en .env.dev, .env.test ou .env.demo
# 2. Adapter les valeurs suivantes :
#    - NODE_ENV : development / test / production
#    - APP_ENV : dev / test / demo
#    - DATABASE_URL : utiliser la base dédiée à l'environnement
#    - REDIS_URL : instance Redis dédiée
#    - FRONTEND_URL / API_URL : domaines propres à l'environnement
#    - CORS_ORIGINS : lister uniquement les origines autorisées
#    - JWT_SECRET / JWT_REFRESH_SECRET : clés différentes par env.
#    - ENCRYPTION_KEY : clé unique par environnement
#    - PAYMENT_API_KEY / PAYMENT_WEBHOOK_SECRET : clés sandbox ou prod
#    - SEUIL_* : valeurs éventuellement différentes (ex: seuil plus bas en dev)
# 3. Ne jamais versionner ces fichiers .env.* !!!
# =====================================================
# ---------------------------
# 16. DÉPLOIEMENT
# ---------------------------
# URL du dépôt Git (utilisée par infra/deploy.sh)
# Peut aussi être définie dans infra/.env.deploy (recommandé)
# FORGES_REPO_URL=https://github.com/votre-org/forges-backend.git
