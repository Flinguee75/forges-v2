    {
      "title": "Login KO / 5m",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 55
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service_name=~\"unknown_service|backend\"} | json | __error__=\"\" | metadata_error=\"INVALID_CREDENTIALS\" | metadata_health_probe != \"true\" [5m]))",
          "refId": "A",
          "legendFormat": "login KO/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#E67E22"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "description": "La probe silent-check genere 1 tentative toutes les 5 min \u2014 taux normal = ~0.003/s. Une hausse indique de vraies tentatives."
    },
