    {
      "title": "Taux echecs / connexions (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 70 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=~\"unknown_service|backend\"} | json | __error__=\"\" | action=\"LOGIN_FAILED\" [1h])) / (sum(count_over_time({service_name=~\"unknown_service|backend\"} | json | __error__=\"\" | action=~\"LOGIN_SUCCESS|LOGIN_FAILED\" [1h])) > 0) * 100",
          "refId": "A",
          "legendFormat": "taux echec %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 20 }, { "color": "red", "value": 50 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },
