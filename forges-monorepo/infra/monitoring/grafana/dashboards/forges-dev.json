      "targets": [
        {
          "expr": "sum(rate({service_name=~\"unknown_service|checker\"} | json | service=\"checker\" | environment=\"dev\" | level=\"error\" [5m]))",
          "refId": "A",
          "legendFormat": "errors/s"
