{
  "info": {
    "name": "FORGES v4.8 - Session 4 Tests Authentifiés",
    "description": "Collection de tests pour les 28 endpoints critiques avec JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    }
  ],
  "item": [
    {
      "name": "AGENT - Reversements Partenaires (GET)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_agent}}"
          }
        ],
        "url": "{{base_url}}/agent/reversements/partenaires"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has data field', () => {",
              "    pm.expect(pm.response.json()).to.have.property('data');",
              "});"
            ]
          }
        }
      ]
    },
